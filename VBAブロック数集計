    baseDir = "C:\WORK\Test"

    ' 取得する年月を配列で指定（yyyymm 形式）
    targetMonths = Array("202510", "202511", "202512", "202601", "202602", "202603")

    ' 出力先シートを指定（ThisWorkbook の 2 番目のシート）
    Set destSheet = ThisWorkbook.Sheets(2)

    ' 出力シートを初期化（既存データを消す）
    destSheet.Cells.Clear

    ' 見出しを A1:E1 に設定（列名を分かりやすく）
    destSheet.Range("A1:E1").Value = Array("会社名", "年月", "URLブロック数 合計", "FILEブロック数 合計", "CATEGORYブロック数 合計")
    destSheet.Range("A1:E1").Font.Bold = True   ' 見出しを太字にする

    currentRow = 2   ' データ書き込み開始行を 2 行目に設定（1 行目は見出し）

    ' FileSystemObject を作成（フォルダ・ファイル操作に使用）
    Set fso = CreateObject("Scripting.FileSystemObject")

    ' 画面更新と警告をオフにして処理を高速化・煩雑なダイアログを抑制
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False ' リンク更新などの警告を非表示にする

    ' 1. baseDir の直下にある各会社フォルダをループ
    For Each companyFolder In fso.GetFolder(baseDir).SubFolders

