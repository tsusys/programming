Sub ExtractDataFromAllCompanies()

    Dim fso As Object
    Dim baseDir As String
    Dim companyFolder As Object
    Dim targetMonths As Variant
    Dim month As Variant
    Dim fileName As String
    Dim fullPath As String
    Dim wbSource As Workbook
    Dim wsSource As Worksheet
    Dim destSheet As Worksheet
    Dim currentRow As Long
    Dim targetRow As Long
    
    'このマクロは運用レポートフォルダを指定するとその中のエクセルを確認してブロック数を抽出できるマクロです。
    
    'ここでフォルダを指定するとフォルダの中のエクセルから 合計 行の値を取得して block シートに出力します。
    baseDir = "C:\WORK\08_2_運用レポート(NEDO)"
    
    '取得する月はここで指定します
    targetMonths = Array("202510", "202511", "202512", "202601", "202602", "202603")
    Set destSheet = ThisWorkbook.Sheets(2)
    
    ' シートの初期化と見出し作成
    destSheet.Cells.Clear
    destSheet.Range("A1:E1").Value = Array("会社名", "年月", "URLブロック数 合計", "FILEブロック数 合計", "CATEGORYブロック数 合計")
    destSheet.Range("A1:E1").Font.Bold = True
    currentRow = 2
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False ' リンク更新などの警告を非表示
    
    ' 1. 各会社のフォルダをループ
    For Each companyFolder In fso.GetFolder(baseDir).SubFolders
        
        ' 2. 指定した年月をループ
        For Each month In targetMonths
            ' ファイル名の組み立て（例：【月次レポート】株式会社堂鳩様_202510.xlsx）
            fileName = "【月次レポート】" & companyFolder.Name & "様_" & month & ".xlsx"
            fullPath = companyFolder.path & "\" & fileName
            
            ' ファイルが存在するか確認
            If fso.FileExists(fullPath) Then
                Set wbSource = Nothing
                On Error Resume Next
                Set wbSource = Workbooks.Open(fileName:=fullPath, ReadOnly:=True)
                On Error GoTo 0
                
                If Not wbSource Is Nothing Then
                    Set wsSource = Nothing
                    On Error Resume Next
                    Set wsSource = wbSource.Sheets("アクセスサマリ")
                    On Error GoTo 0
                    
                    If Not wsSource Is Nothing Then
                        ' 「合計」行を探す
                        targetRow = 0
                        On Error Resume Next
                        targetRow = wsSource.Columns("A").Find(What:="合計", LookIn:=xlValues, LookAt:=xlWhole).Row
                        On Error GoTo 0
                        
                        ' データをシートに書き込み
                        destSheet.Cells(currentRow, 1).Value = companyFolder.Name
                        destSheet.Cells(currentRow, 2).Value = month
                        
                        If targetRow > 0 Then
                            destSheet.Cells(currentRow, 3).Value = wsSource.Cells(targetRow, "C").Value
                            destSheet.Cells(currentRow, 4).Value = wsSource.Cells(targetRow, "D").Value
                            destSheet.Cells(currentRow, 5).Value = wsSource.Cells(targetRow, "E").Value
                        Else
                            destSheet.Cells(currentRow, 3).Value = "合計行なし"
                        End If
                    Else
                        destSheet.Cells(currentRow, 1).Value = companyFolder.Name
                        destSheet.Cells(currentRow, 2).Value = month & " (シートなし)"
                    End If
                    wbSource.Close SaveChanges:=False
                    currentRow = currentRow + 1
                End If
            End If
        Next month
    Next companyFolder
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "すべての会社のデータ抽出が完了しました。", vbInformation
End Sub
